{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "glint-telemetry",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "analytics_engine_datasets": [
    {
      "binding": "EVENTS",
      "dataset": "glint_events"
    }
  ]
}
